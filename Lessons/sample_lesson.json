import SwiftUI

struct LessonSlideViewWithSources: View {
    @Binding var lessonPoint: LessonPoint

    var body: some View {
        VStack(alignment: .leading) {
            TextField("Title", text: $lessonPoint.title)
                .font(.headline)
            if let summary = lessonPoint.summary {
                TextField("Summary", text: Binding($lessonPoint.summary, default: ""))
                    .font(.subheadline)
            } else {
                TextField("Summary", text: Binding($lessonPoint.summary, default: ""))
                    .font(.subheadline)
            }
            List {
                Section(header: Text("Subpoints")) {
                    ForEach(lessonPoint.subpoints.indices, id: \.self) { index in
                        TextField("Subpoint", text: Binding(
                            get: { lessonPoint.subpoints[index] },
                            set: { lessonPoint.subpoints[index] = $0 }
                        ))
                    }
                    .onDelete { indices in
                        lessonPoint.subpoints.remove(atOffsets: indices)
                    }
                    Button("Add Subpoint") {
                        lessonPoint.subpoints.append("")
                    }
                }
                Section(header: Text("Quotes")) {
                    if let quotesBinding = Binding($lessonPoint.quotes, default: []) {
                        ForEach(quotesBinding.wrappedValue.indices, id: \.self) { index in
                            TextField("Quote", text: Binding(
                                get: { quotesBinding.wrappedValue[index] },
                                set: { quotesBinding.wrappedValue[index] = $0 }
                            ))
                        }
                        .onDelete { indices in
                            quotesBinding.wrappedValue.remove(atOffsets: indices)
                        }
                        Button("Add Quote") {
                            quotesBinding.wrappedValue.append("")
                        }
                    }
                }
            }
        }
        .padding()
    }
}
