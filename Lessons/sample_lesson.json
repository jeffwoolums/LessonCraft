import Foundation

struct LessonPoint: Identifiable, Codable, Hashable {
    var id: UUID = UUID()  // Defaulted to auto-generate a UUID if none provided
    let title: String
    let summary: String?
    let subpoints: [String]
    let quotes: [String]?

    // Custom decoding to handle missing "id" gracefully
    init(from decoder: Decoder) throws {
        let container = try decoder.container(keyedBy: CodingKeys.self)
        self.id = try container.decodeIfPresent(UUID.self, forKey: .id) ?? UUID()
        self.title = try container.decode(String.self, forKey: .title)
        self.summary = try container.decodeIfPresent(String.self, forKey: .summary)
        self.subpoints = try container.decode([String].self, forKey: .subpoints)
        self.quotes = try container.decodeIfPresent([String].self, forKey: .quotes)
    }

    init(title: String, summary: String? = nil, subpoints: [String], quotes: [String]? = nil) {
        self.id = UUID()
        self.title = title
        self.summary = summary
        self.subpoints = subpoints
        self.quotes = quotes
    }

    enum CodingKeys: String, CodingKey {
        case id, title, summary, subpoints, quotes
    }
}
